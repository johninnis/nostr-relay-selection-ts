[
  { "name": "null input returns null", "input": null, "expected": null },
  { "name": "empty string returns null", "input": "", "expected": null },
  { "name": "whitespace-only string returns null", "input": "   ", "expected": null },
  { "name": "returns wss URL unchanged", "input": "wss://relay.example.com", "expected": "wss://relay.example.com" },
  { "name": "strips single trailing slash", "input": "wss://relay.example.com/", "expected": "wss://relay.example.com" },
  { "name": "strips multiple trailing slashes", "input": "wss://relay.example.com///", "expected": "wss://relay.example.com" },
  { "name": "lowercases hostname", "input": "wss://Relay.Example.COM", "expected": "wss://relay.example.com" },
  { "name": "lowercases protocol", "input": "WSS://relay.example.com", "expected": "wss://relay.example.com" },
  { "name": "strips default wss port :443", "input": "WSS://relay.example.com:443/", "expected": "wss://relay.example.com" },
  { "name": "strips default ws port :80", "input": "ws://relay.example.com:80", "expected": "ws://relay.example.com" },
  { "name": "preserves non-default port", "input": "wss://relay.example.com:444", "expected": "wss://relay.example.com:444" },
  { "name": "preserves wss on port 80", "input": "wss://relay.example.com:80", "expected": "wss://relay.example.com:80" },
  { "name": "preserves ws on port 443", "input": "ws://relay.example.com:443", "expected": "ws://relay.example.com:443" },
  { "name": "preserves non-empty path", "input": "wss://relay.example.com/nostr", "expected": "wss://relay.example.com/nostr" },
  { "name": "strips trailing slash after a path", "input": "wss://relay.example.com/nostr/", "expected": "wss://relay.example.com/nostr" },
  { "name": "strips trailing comma after path", "input": "wss://relay.snort.social/,", "expected": "wss://relay.snort.social" },
  { "name": "strips trailing period after path", "input": "wss://relay.damus.io/.", "expected": "wss://relay.damus.io" },
  { "name": "strips trailing semicolon after path", "input": "wss://relay.damus.io/;", "expected": "wss://relay.damus.io" },
  { "name": "preserves query string", "input": "wss://relay.example.com?auth=token", "expected": "wss://relay.example.com?auth=token" },
  { "name": "accepts ipv4 host with port", "input": "wss://127.0.0.1:8080", "expected": "wss://127.0.0.1:8080" },
  { "name": "invalid URL with trailing slash is rejected", "input": "not-a-url/", "expected": null },
  { "name": "invalid URL without trailing slash is rejected", "input": "not-a-url", "expected": null },
  { "name": "http scheme is rejected", "input": "http://relay.example.com", "expected": null },
  { "name": "https scheme is rejected", "input": "https://relay.example.com", "expected": null },
  { "name": "javascript scheme is rejected", "input": "javascript:alert(1)", "expected": null },
  { "name": "rejects fragment", "input": "wss://relay.example.com/#fragment", "expected": null },
  { "name": "rejects percent-encoded space in path", "input": "wss://relay.example.com/path%20with%20spaces", "expected": null },
  { "name": "rejects space in host", "input": "wss://relay example.com", "expected": null },
  { "name": "rejects host starting with dot", "input": "wss://.relay.example.com", "expected": null },
  { "name": "rejects host ending with dot", "input": "wss://relay.example.com.", "expected": null },
  { "name": "rejects port zero", "input": "wss://relay.example.com:0", "expected": null },
  { "name": "rejects port above 65535", "input": "wss://relay.example.com:70000", "expected": null },
  { "name": "rejects double slashes in path", "input": "wss://relay.example.com//bad", "expected": null },
  { "name": "rejects hostname appearing in path", "input": "wss://relay.snort.social/relay.snort.social", "expected": null },
  { "name": "rejects concatenated wss URLs", "input": "wss://relay.example.com/wss://other.relay.com", "expected": null },
  { "name": "rejects URL longer than 200 characters", "input": "wss://relay.example.com/aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "expected": null },
  { "name": "rejects unicode in host", "input": "wss://⬤ wss//nostr-pub.wellorder.net", "expected": null }
]
