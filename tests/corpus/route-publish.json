[
  {
    "name": "kind 1 with p-tags and cached kind 10002 fans out to recipient inboxes",
    "event": {
      "kind": 1,
      "pubkey": "1111111111111111111111111111111111111111111111111111111111111111",
      "created_at": 100,
      "tags": [
        [
          "p",
          "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
        ],
        [
          "p",
          "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb"
        ]
      ]
    },
    "context": {
      "userPubkey": "1111111111111111111111111111111111111111111111111111111111111111",
      "relayListEvents": [
        {
          "kind": 10002,
          "pubkey": "1111111111111111111111111111111111111111111111111111111111111111",
          "created_at": 1,
          "tags": [
            [
              "r",
              "wss://user-write.example.com",
              "write"
            ]
          ]
        },
        {
          "kind": 10002,
          "pubkey": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
          "created_at": 1,
          "tags": [
            [
              "r",
              "wss://alice-inbox.example.com",
              "read"
            ]
          ]
        },
        {
          "kind": 10002,
          "pubkey": "bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
          "created_at": 1,
          "tags": [
            [
              "r",
              "wss://bob-inbox.example.com",
              "read"
            ]
          ]
        }
      ],
      "privateContentRelays": [],
      "indexerRelays": []
    },
    "expected": {
      "branch": "general",
      "relays": [
        "wss://user-write.example.com",
        "wss://alice-inbox.example.com",
        "wss://bob-inbox.example.com"
      ]
    }
  },
