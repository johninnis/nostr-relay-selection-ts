{
  "name": "@innis/nostr-relay-selection",
  "version": "0.1.3",
  "license": "MIT",
  "exports": "./mod.ts",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/path": "jsr:@std/path@^1"
  },
  "tasks": {
    "check": "deno check mod.ts example.ts src/ tests/",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "test": "deno test -A",
    "coverage": "rm -rf cov_profile && deno test -A --coverage=cov_profile && deno coverage cov_profile --lcov --output=cov_profile/lcov.info && deno coverage cov_profile && deno run --allow-read scripts/check-coverage.ts",
    "exports-tested": "deno run --allow-read --allow-run scripts/check-exports-tested.ts",
    "docs": "deno run --allow-read --allow-run scripts/check-docs.ts",
    "publish:dry": "deno publish --dry-run",
    "ci": "deno task fmt:check && deno task lint && deno task check && deno task coverage && deno task exports-tested && deno task docs"
  },
  "lint": {
    "plugins": ["./scripts/lint-plugins/innis-rules.ts"],
    "rules": {
      "include": ["no-console", "ban-untagged-todo", "explicit-function-return-type", "no-non-null-assertion"],
      "exclude": ["require-await"]
    },
    "exclude": ["cov_profile/"]
  },
  "fmt": {
    "semiColons": false,
    "lineWidth": 120,
    "exclude": ["**/*.md", "cov_profile/"]
  }
}
